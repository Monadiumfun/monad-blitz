# === Local browser testing without Telegram (LOCAL ONLY) ===
# Set BOTH to the same random value to enable the x-dev-user bypass locally.
# NEVER set these in a deployed/tunneled env: with the secret present, anyone
# could impersonate any account via an x-dev-user header. Leave blank in prod.
DEV_AUTH_SECRET=
VITE_DEV_AUTH_SECRET=
